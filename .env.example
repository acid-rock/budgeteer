# Copy this file to .env and fill in the values.
# For local development, put env-specific overrides in .env.local (gitignored).

# ── Database (Neon / PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
DIRECT_URL=postgresql://user:password@host-direct/db?sslmode=require

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Production app  → callback: https://yourdomain.com/api/auth/callback/github
# Development app → callback: http://localhost:3000/api/auth/callback/github
# Create at: github.com/settings/developers → OAuth Apps
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Throttles /api/* per IP via middleware. Create a Redis database at
# console.upstash.com → copy the REST URL + token. Optional locally: when unset,
# rate limiting is simply disabled and the app runs normally.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Error sink (optional) ────────────────────────────────────────────────────
# In production, error-level logs are POSTed (fire-and-forget) to this webhook so
# unhandled server errors reach an external service — Sentry, Better Stack, a
# Slack/Discord webhook, etc. Unset locally / in dev → no forwarding. Dormant when
# Sentry (below) is configured; kept as a generic fallback seam.
ERROR_SINK_URL=

# ── Sentry (optional, recommended) ───────────────────────────────────────────
# Client + server error monitoring. Create a project at sentry.io → copy its DSN.
# When unset, the SDK initializes disabled and the app runs normally. Browser
# events tunnel through the same-origin /monitoring route (CSP-friendly).
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only — set in CI to upload source maps so stack traces de-minify.
# Safe to leave blank locally; the build just skips the upload.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
