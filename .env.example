# Copy this file to .env and fill in the values.
# For local development, put env-specific overrides in .env.local (gitignored).

# ── Database (Neon / PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
DIRECT_URL=postgresql://user:password@host-direct/db?sslmode=require

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Production app  → callback: https://yourdomain.com/api/auth/callback/github
# Development app → callback: http://localhost:3000/api/auth/callback/github
# Create at: github.com/settings/developers → OAuth Apps
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
