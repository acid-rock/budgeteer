// Prisma schema for Budgeteer — a personal finance tracker.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth (Auth.js / NextAuth v5, Prisma adapter) ───────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]

  // App data owned by this user.
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App data ───────────────────────────────────────────────────────────────

// A spending/income bucket, e.g. "Groceries", "Salary".
model Category {
  id           String        @id @default(cuid())
  name         String
  // "income" categories never get budgets; kept simple as a plain string flag.
  kind         String        @default("expense") // "income" | "expense"
  transactions Transaction[]
  budgets      Budget[]
  createdAt    DateTime      @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Each user gets their own taxonomy: same name can exist across users.
  @@unique([userId, name, kind])
  @@index([userId])
}

// A single money movement: income or expense.
model Transaction {
  id         String   @id @default(cuid())
  type       String // "income" | "expense"
  amount     Decimal  @db.Decimal(12, 2) // positive; `type` gives the direction
  date       DateTime @default(now())
  note       String?
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([categoryId])
  @@index([userId])
}

// A monthly spending limit for one category.
// `month` is the first day of the month (UTC), e.g. 2026-05-01, for easy range queries.
model Budget {
  id         String   @id @default(cuid())
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
  month      DateTime
  limit      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One budget per category per month.
  @@unique([categoryId, month])
  @@index([userId])
}
